# Copy this file to .env and fill in your values
# NEVER commit the real .env file to version control

# Flask secret key — use a long random string in production
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-string-in-production

# Environment: development | production
FLASK_ENV=development

# Database
# Development (SQLite):
DATABASE_URL=sqlite:///edushield.db
# Production (PostgreSQL on Render):
# DATABASE_URL=postgresql://user:password@host:5432/edushield

# Security
WTF_CSRF_ENABLED=True
SESSION_COOKIE_SECURE=False   # Set True in production (requires HTTPS)
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Rate limiting
# This MUST match the format Flask-Limiter expects (semicolon-separated
# multi-window limits). See backend/config.py BaseConfig.RATELIMIT_DEFAULT
# for the authoritative value — keep this in sync if you change it there.
RATELIMIT_DEFAULT=200 per day;50 per hour;10 per minute

# CORS allowlist — comma-separated list of origins allowed to call /api/*
# endpoints from JavaScript running on a different domain. Used by
# backend/app.py's CORS() setup. In development "*" is fine; in
# production, restrict this to your actual deployed domain(s).
ALLOWED_ORIGINS=*

# Admin credentials (for initial setup only — change immediately after)
ADMIN_EMAIL=admin@edushield.ng
ADMIN_PASSWORD=ChangeMe123!
